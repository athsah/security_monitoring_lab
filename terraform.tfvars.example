# ── Copy to terraform.tfvars and fill in your values ──────────

aws_region         = "us-west-1"
project_name       = "seclab"
environment        = "dev"
vpc_cidr           = "10.0.0.0/16"
public_subnet_cidr = "10.0.1.0/24"

# Your public IP — https://whatismyip.com (add /32)
allowed_cidr = "YOUR.IP.HERE/32"

# EC2 key pair name (AWS Console → EC2 → Key Pairs)
key_name = "your-key-pair-name"

# Splunk admin password (min 8 chars, must contain letter + number)
splunk_password = "Seclab123!"

# PostgreSQL seclab_user password
db_password = "Seclab456!"


