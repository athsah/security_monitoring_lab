# ─────────────────────────────────────────────────────────────────
# Copy this to terraform.tfvars and fill in your real values.
# terraform.tfvars is gitignored — never commit it.
# ─────────────────────────────────────────────────────────────────

aws_region          = "us-east-1"
project_name        = "seclab"
environment         = "dev"
vpc_cidr            = "10.0.0.0/16"
public_subnet_cidr  = "10.0.1.0/24"
private_subnet_cidr = "10.0.2.0/24"

# Your public IP — find it at https://whatismyip.com  (add /32 at the end)
allowed_cidr = "YOUR.IP.HERE/32"

# Name of your EC2 key pair (create one in the AWS Console under EC2 → Key Pairs)
key_name = "your-key-pair-name"

# S3 bucket names are globally unique across ALL AWS accounts
# Add your name/initials to make it unique (e.g. "seclab-dev-logs-jsmith")
log_bucket_name = "seclab-dev-logs-yourname"
